{
  "name": "bobanana5",
  "description": "鲍勃安娜 5.0 — 可编程状态机管线 + 角色卡系统 + GUI 仪表盘",
  "version": "5.0.0",
  "tools": [
    {
      "name": "bobanana_pipeline",
      "description": "一键运行完整管线：架构师→开发→测试→评判→挑刺→CL终审",
      "inputSchema": {
        "type": "object",
        "properties": {
          "goal": {
            "type": "string",
            "description": "项目目标描述"
          }
        },
        "required": ["goal"]
      }
    },
    {
      "name": "bobanana_dashboard",
      "description": "启动 TUI 仪表盘，显示状态机图、角色卡、管线进度",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "bobanana_cards",
      "description": "列出所有可用角色卡",
      "inputSchema": {
        "type": "object",
        "properties": {
          "tag": {
            "type": "string",
            "description": "按标签过滤：OP/CL/HR"
          }
        }
      }
    },
    {
      "name": "bobanana_test",
      "description": "运行全部测试并输出报告",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "bobanana_get_state_machine",
      "description": "获取当前状态机拓扑",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "状态机文件路径，默认 state-machine.yaml"
          }
        }
      }
    },
    {
      "name": "bobanana_get_role_card",
      "description": "获取角色卡详情",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "角色卡名称"
          }
        },
        "required": ["name"]
      }
    },
    {
      "name": "bobanana_schedule_create",
      "description": "创建定时任务：指定目标、时间、频率，注册到 Windows 任务计划程序",
      "inputSchema": {
        "type": "object",
        "properties": {
          "goal": {
            "type": "string",
            "description": "管线目标描述（≤200字符）"
          },
          "time": {
            "type": "string",
            "description": "执行时间 (HH:MM 格式)"
          },
          "weekday": {
            "type": "string",
            "description": "执行频率：daily(默认)/mon-fri/weekend/mon/tue/wed/thu/fri/sat/sun"
          },
          "rounds": {
            "type": "integer",
            "description": "轮数（默认1）"
          }
        },
        "required": ["goal", "time"]
      }
    },
    {
      "name": "bobanana_schedule_list",
      "description": "列出所有已注册的定时任务",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "bobanana_schedule_remove",
      "description": "删除指定定时任务",
      "inputSchema": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "description": "任务 ID（8位hex）"
          }
        },
        "required": ["task_id"]
      }
    },
    {
      "name": "bobanana_schedule_trigger",
      "description": "手动触发指定定时任务立即执行",
      "inputSchema": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "description": "任务 ID（8位hex）"
          }
        },
        "required": ["task_id"]
      }
    },
    {
      "name": "bobanana_schedule_logs",
      "description": "查询定时任务的执行历史日志",
      "inputSchema": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "description": "可选，按任务ID过滤"
          },
          "limit": {
            "type": "integer",
            "description": "返回条数（默认10）"
          }
        }
      }
    }
  ],
  "resources": [
    {
      "uri": "bobanana://state-machine",
      "name": "当前状态机配置",
      "description": "state-machine.yaml 的实时内容"
    },
    {
      "uri": "bobanana://dashboard",
      "name": "完整仪表盘数据",
      "description": "状态机 + 角色卡 + 管线进度的综合数据"
    }
  ]
}
